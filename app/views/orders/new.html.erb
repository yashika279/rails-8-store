<div class="container mt-4">
  <div class="row">
    <div class="col-lg-8">
      <div class="card mb-3">
        <div class="card-header">
          Delivery Address
        </div>

        <div class="card-body">

          <% if @default_address.present? %>

            <h6>
              <%= @default_address.full_name %>
            </h6>

            <p>
              <%= @default_address.address_line_1 %>,
              <%= @default_address.city %>,
              <%= @default_address.state %>
            </p>

            <%= link_to "Change",
                        addresses_path,
                        class: "btn btn-outline-primary btn-sm" %>

          <% else %>

            <%= link_to "Add Address",
                        new_address_path,
                        class: "btn btn-primary" %>

          <% end %>

        </div>
      </div>
      <div class="card">
        <div class="card-header">
          Order Items
        </div>

        <div class="card-body">

          <% @cart.cart_items.each do |item| %>

            <div class="row mb-3">

              <div class="col-md-2">
                <%= image_tag item.product.thumbnail,
                              class: "img-fluid" %>
              </div>

              <div class="col-md-10">

                <h6>
                  <%= item.product.title %>
                </h6>

                <p>
                  Qty:
                  <%= item.quantity %>
                </p>

                <p>
                  ₹<%= item.product.discounted_price %>
                </p>

              </div>

            </div>

            <hr>

          <% end %>

        </div>
      </div>
    </div>

    <div class="col-lg-4">
      <div class="card sticky-top">
        <div class="card-body">

          <h5>
            Price Details
          </h5>

          <hr>

          <p>
            Total Items:
            <%= @cart.cart_items.sum(:quantity) %>
          </p>

          <p>
            MRP:
            ₹<%= @cart.cart_items.sum { |i| i.product.price * i.quantity } %>
          </p>

          <p class="text-success">
            Discount:
            ₹<%= @cart.cart_items.sum { |i| (i.product.price - i.product.discounted_price) * i.quantity } %>
          </p>

          <hr>

          <h5>
            Total:
            ₹<%= @cart.total_amount %>
          </h5>

          <%= form_with url: orders_path do |f| %>

            <%= hidden_field_tag :address_id,
                                @default_address&.id %>

            <%= f.submit "Place Order",
                        class: "btn btn-danger w-100 mt-3" %>

          <% end %>

        </div>
      </div>
    </div>
  </div>
</div>
