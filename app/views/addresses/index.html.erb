<div class="d-flex justify-content-between align-items-center mb-4">
  <h2>My Addresses</h2>

  <%= link_to "Add Address",
              new_address_path,
              class: "btn btn-primary" %>
</div>


<% @addresses.each do |address|%>
  <div class="card mb-3">
    <div class="card-body">

      <div class="d-flex justify-content-between">
        <h5>
          <%= address.address_type.titleize %>

          <% if address.default? %>
            <span class="badge bg-success">
              Default
            </span>
          <% end %>
        </h5>
      </div>

      <p class="fw-bold mb-1">
        <%= address.full_name %>
      </p>

      <p>
        <%= address.phone %>
      </p>

      <p>
        <%= address.address_line_1 %>,
        <%= address.city %>,
        <%= address.state %>,
        <%= address.postal_code %>
      </p>

      <div class="mt-3">
        <%= link_to "Edit",
                    edit_address_path(address),
                    class: "btn btn-outline-primary btn-sm" %>

        <%= button_to "Delete",
                      address_path(address),
                      method: :delete,
                      class: "btn btn-outline-danger btn-sm d-inline" %>
      </div>

    </div>
</div>
<% end %>