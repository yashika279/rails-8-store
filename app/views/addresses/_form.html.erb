<%= form_with model: address do |f| %>

  <div class="mb-3">
    <%= f.label :full_name %>
    <%= f.text_field :full_name,
                     class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :phone %>
    <%= f.text_field :phone,
                     class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :address_line_1 %>
    <%= f.text_field :address_line_1,
                     class: "form-control" %>
  </div>

  <div class="mb-3">
    <%= f.label :address_line_2 %>
    <%= f.text_field :address_line_2,
                     class: "form-control" %>
  </div>

  <div class="row">
    <div class="col-md-4">
      <%= f.text_field :city,
                       placeholder: "City",
                       class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= f.text_field :state,
                       placeholder: "State",
                       class: "form-control" %>
    </div>

    <div class="col-md-4">
      <%= f.text_field :postal_code,
                       placeholder: "Postal Code",
                       class: "form-control" %>
    </div>
  </div>

  <div class="mt-3">
    <%= f.select :address_type,
                 Address.address_types.keys.map { |t| [t.titleize, t] },
                 {},
                 class: "form-select" %>
  </div>

  <div class="form-check mt-3">
    <%= f.check_box :default,
                    class: "form-check-input" %>

    <%= f.label :default,
                "Set as default address",
                class: "form-check-label" %>
  </div>

  <div class="mt-4">
    <%= f.submit class: "btn btn-primary" %>
  </div>

<% end %>